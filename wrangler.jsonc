{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "relayx",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-06",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    // Per-target upstream config. Add more slots by incrementing the trailing
    // number (OPENAI_BASE_2, ...). Each OpenAI target needs BASE, KEY (a secret
    // set via `wrangler secret put`), and MODEL; OPENAI_WIRE_<N> is optional
    // (defaults to chat_completions; set to 'responses' for a Responses target).
    // Anthropic targets need BASE, AUTH (a secret), and MODEL.
    "OPENAI_BASE_1": "https://openrouter.ai/api/v1",
    "OPENAI_MODEL_1": "nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free,tencent/hy3:free,poolside/laguna-m.1:free,nvidia/nemotron-3-nano-30b-a3b:free"
  }
}
